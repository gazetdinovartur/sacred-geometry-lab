{% extends 'base.html.twig' %}

{% block body %}
<section class="lab">
    <div class="lab__intro">
        <h1 class="lab__question">Как ты сейчас?</h1>
    </div>

    <div class="lab__workspace" :class="{ 'is-fullscreen': $store.lab.isFullscreen }">
        <div class="lab__fullscreen-bar">
            <div class="mode-switch mode-switch--fullscreen">
                <button type="button"
                        class="mode-switch__btn"
                        :class="{ 'is-active': $store.lab.mode === 'live' }"
                        @click="$store.lab.setMode('live')">
                    Live
                </button>
                <button type="button"
                        class="mode-switch__btn"
                        :class="{ 'is-active': $store.lab.mode === 'process' }"
                        @click="$store.lab.setMode('process')">
                    Process
                </button>
            </div>
            <button type="button"
                    class="btn btn--ghost btn--sm lab__fullscreen-exit"
                    @click="$store.lab.toggleFullscreen()">
                Свернуть
            </button>
        </div>

        <div class="lab__viz-block">
            <div class="calibration-panel" x-show="$store.lab.isCalibrating" x-cloak>
                <div class="calibration-panel__head">
                    <span class="calibration-panel__title">Калибровка · ~12 сек</span>
                    <span class="calibration-panel__pct" x-text="`${$store.lab.calibrationProgress}%`"></span>
                </div>
                <p class="calibration-panel__prompt" x-text="$store.lab.calibrationPrompt"></p>
                <div class="calibration-panel__bar" role="progressbar"
                     :aria-valuenow="$store.lab.calibrationProgress"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    <div class="calibration-panel__fill"
                         :style="`width: ${$store.lab.calibrationProgress}%`"></div>
                </div>
                <p class="calibration-panel__hint"
                   x-show="$store.lab.rmsNorm > 5"
                   x-cloak>
                    Слышу тебя — круг показывает уровень и спектр
                </p>
                <button type="button"
                        class="btn btn--ghost btn--sm calibration-panel__skip"
                        @click="$store.lab.skipCalibration()">
                    Пропустить калибровку
                </button>
            </div>

            <div class="lab__viz" :class="{ 'is-listening': $store.lab.isActive && !$store.lab.isPaused && !$store.lab.isCalibrating,
                                              'is-calibrating': $store.lab.isCalibrating }">
                <canvas id="mandala-canvas" class="spectrum-canvas" aria-label="Спектр голоса"></canvas>
                <button type="button"
                        class="mandala-fullscreen"
                        @click="$store.lab.toggleFullscreen()"
                        :aria-label="$store.lab.isFullscreen ? 'Выйти из полноэкранного режима' : 'На весь экран'">
                    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 9V4h5M15 4h5v5M20 15v5h-5M9 20H4v-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </button>
                <p class="mandala-status"
                   :class="{ 'mandala-status--notice': $store.lab.status }"
                   x-text="$store.lab.status"
                   x-show="$store.lab.status && !$store.lab.isCalibrating"></p>
            </div>
        </div>

        <div class="widgets" x-show="($store.lab.isActive || $store.lab.hasSession) && !$store.lab.isCalibrating">
            <div class="widget widget--rms" title="Громкость">
                <span class="widget__label">Уровень</span>
                <span class="widget__desc">громкость → кольцо</span>
                <div class="widget__bar">
                    <div class="widget__fill" :style="`width: ${$store.lab.rmsNorm}%`"></div>
                </div>
            </div>
            <div class="widget widget--pitch" title="Нота и октава">
                <span class="widget__label">Тон</span>
                <span class="widget__desc">нота · октава</span>
                <span class="widget__value" x-text="$store.lab.toneLabel"></span>
            </div>
            <div class="widget widget--silence" title="Тишина — Rest & Breath">
                <span class="widget__label">Покой</span>
                <span class="widget__desc">тишина → дыхание</span>
                <span class="widget__value" x-text="$store.lab.silenceLabel"></span>
            </div>
        </div>

        <div class="process-panel"
             x-show="$store.lab.mode === 'process' && ($store.lab.isActive || $store.lab.timeline.length)">
            <div class="process-panel__header">
                <span class="process-panel__title">След процесса</span>
                <button type="button"
                        class="btn btn--ghost btn--sm"
                        x-show="$store.lab.activeSnapshot !== null && $store.lab.hasSession"
                        @click="$store.lab.showLive()">
                    Сейчас
                </button>
            </div>
            <p class="process-panel__hint"
               x-show="$store.lab.isActive && !$store.lab.timeline.length">
                Говори и молчи — этап каждые ~12 с, пока не «Стоп».
            </p>
            <p class="process-panel__hint"
               x-show="!$store.lab.isActive && $store.lab.activeSnapshot === -1">
                Итог — среднее по этапам. Экспорт соберёт форму из показателей.
            </p>
            <div class="process-timeline-scroll" x-show="$store.lab.timeline.length">
                <div class="process-timeline">
                <template x-for="entry in $store.lab.timeline" :key="entry.index">
                    <button type="button"
                            class="process-timeline__item"
                            :class="{
                                'is-active': $store.lab.activeSnapshot === entry.index,
                                'is-composite': entry.isComposite
                            }"
                            @click="$store.lab.selectSnapshot(entry.index)"
                            x-text="entry.label"></button>
                </template>
                </div>
            </div>
        </div>

        <div class="lab__controls">
            <div class="mic-permission"
                 x-show="$store.lab?.micDenied"
                 x-cloak>
                <p class="mic-permission__text">
                    Без микрофона я тебя не слышу. Если ты нажал «Запретить» — разреши доступ в настройках браузера для этого сайта.
                </p>
                <button type="button"
                        class="btn btn--primary"
                        @click="$store.lab.retryMicrophone()"
                        :disabled="$store.lab.isStarting">
                    <span x-text="$store.lab.isStarting ? 'Подключение…' : 'Разрешить микрофон'"></span>
                </button>
            </div>

            <button type="button"
                    class="btn btn--primary"
                    @click="$store.lab.primaryAction()"
                    x-show="!$store.lab.isActive && !$store.lab.micDenied"
                    :disabled="$store.lab.isStarting">
                <span x-text="$store.lab.isStarting ? 'Подключение…' : $store.lab.primaryLabel()"></span>
            </button>
            <button type="button"
                    class="btn btn--ghost"
                    @click="$store.lab.pause()"
                    x-show="$store.lab.isActive"
                    :disabled="!$store.lab.isActive">
                <span x-text="$store.lab.isPaused ? 'Продолжить' : 'Пауза'"></span>
            </button>
            <button type="button"
                    class="btn btn--ghost"
                    @click="$store.lab.stop()"
                    x-show="$store.lab.isActive || $store.lab.hasSession">
                Стоп
            </button>
            <button type="button"
                    class="btn btn--ghost"
                    @click="$store.lab.toggleFullscreen()"
                    :aria-label="$store.lab.isFullscreen ? 'Свернуть' : 'На весь экран'">
                <span x-text="$store.lab.isFullscreen ? 'Свернуть' : 'На весь экран'"></span>
            </button>
            <button type="button"
                    class="btn btn--ghost"
                    @click="$store.lab.recalibrate()"
                    :disabled="$store.lab.isStarting || $store.lab.isCalibrating"
                    x-show="!$store.lab.isCalibrating">
                <span x-text="$store.lab.isActive ? 'Перекалибровать' : 'Калибровка'"></span>
            </button>
            <div class="export-form"
                 x-show="$store.lab.hasSession && !$store.lab.isActive"
                 x-cloak>
                <label class="export-field">
                    <span class="export-field__label">Размер</span>
                    <select class="export-control"
                            x-model.number="$store.lab.exportSize">
                        <option :value="1600">1600×1600</option>
                        <option :value="800">800×800</option>
                        <option :value="3200">3200×3200</option>
                    </select>
                </label>
                <label class="export-field" x-show="$store.lab.exportAction !== 'video'">
                    <span class="export-field__label">Стиль</span>
                    <select class="export-control"
                            x-model="$store.lab.exportStyle">
                        <option value="dots">Точечная</option>
                        <option value="layers">Слои</option>
                    </select>
                </label>
                <label class="export-field">
                    <span class="export-field__label">Действие</span>
                    <select class="export-control"
                            x-model="$store.lab.exportAction"
                            :key="`export-actions-${$store.lab.processSnapshotCount}`">
                        <template x-for="opt in $store.lab.exportActions" :key="opt.value">
                            <option :value="opt.value" x-text="opt.label"></option>
                        </template>
                    </select>
                </label>
                <button type="button"
                        class="btn btn--ghost export-control"
                        @click="$store.lab.runExportAction()"
                        x-text="$store.lab.exportActionButtonLabel()"></button>
            </div>
            <div class="save-notice"
                 x-show="$store.lab.saveNotice"
                 x-cloak
                 role="status"
                 aria-live="polite">
                <p class="save-notice__text">
                    Узор «<strong x-text="$store.lab.saveNotice?.title"></strong>» сохранён в своё место
                </p>
                <div class="save-notice__actions">
                    <a class="btn btn--primary btn--sm save-notice__link"
                       :href="`/account#pattern-${$store.lab.saveNotice?.id}`">
                        Открыть
                    </a>
                    <button type="button"
                            class="btn btn--ghost btn--sm"
                            @click="$store.lab.dismissSaveNotice()">
                        Закрыть
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
